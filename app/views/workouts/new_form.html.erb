<div class="row justify-content-center">
  <div class="col-md-8">
    <a href="<%= workouts_path %>" class="text-decoration-none mb-3 d-inline-block">← Back to workouts</a>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h2 class="mb-4"><i class="bi bi-plus-circle"></i> Log a Workout</h2>

        <p class="text-muted">Fill in what you know — the AI will automatically categorize your workout based on the details you provide.</p>

        <form action="<%= create_workout_path %>" method="post">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

          <div class="mb-3">
            <label for="title" class="form-label">Activity Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="title" name="title" placeholder="e.g., Morning Run, Bench Press, Pool Laps" required>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="workout_date" class="form-label">Date <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="workout_date" name="workout_date" value="<%= Date.today %>" required>
            </div>
            <div class="col-md-6">
              <label for="duration_minutes" class="form-label">Duration (minutes)</label>
              <input type="number" class="form-control" id="duration_minutes" name="duration_minutes" placeholder="e.g., 45">
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <label for="distance_km" class="form-label">Distance (km)</label>
              <input type="number" step="0.1" class="form-control" id="distance_km" name="distance_km" placeholder="e.g., 5.0">
            </div>
            <div class="col-md-4">
              <label for="heart_rate_avg" class="form-label">Avg Heart Rate (bpm)</label>
              <input type="number" class="form-control" id="heart_rate_avg" name="heart_rate_avg" placeholder="e.g., 145">
            </div>
            <div class="col-md-4">
              <label for="heart_rate_max" class="form-label">Max Heart Rate (bpm)</label>
              <input type="number" class="form-control" id="heart_rate_max" name="heart_rate_max" placeholder="e.g., 172">
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="calories" class="form-label">Calories Burned</label>
              <input type="number" class="form-control" id="calories" name="calories" placeholder="e.g., 320">
            </div>
            <div class="col-md-6">
              <label for="category_id" class="form-label">Category (optional — AI will auto-detect)</label>
              <select class="form-select" id="category_id" name="category_id">
                <option value="">Let AI decide 🤖</option>
                <% Category.all.each do |category| %>
                  <option value="<%= category.id %>"><%= category_icon(category.name) %> <%= category.name %></option>
                <% end %>
              </select>
            </div>
          </div>

          <div class="mb-4">
            <label for="notes" class="form-label">Notes</label>
            <textarea class="form-control" id="notes" name="notes" rows="3" placeholder="How did it feel? Any PRs?"></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg w-100">
            <i class="bi bi-check-lg"></i> Save Workout
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

