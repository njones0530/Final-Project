<div class="row justify-content-center">
  <div class="col-md-8">
    <a href="<%= workout_path(@workout) %>" class="text-decoration-none mb-3 d-inline-block">← Back to workout</a>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h2 class="mb-4"><i class="bi bi-pencil"></i> Edit Workout</h2>

        <form action="<%= update_workout_path(@workout) %>" method="post">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <input type="hidden" name="_method" value="patch">

          <div class="mb-3">
            <label for="title" class="form-label">Activity Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="title" name="title" value="<%= @workout.title %>" required>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="workout_date" class="form-label">Date <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="workout_date" name="workout_date" value="<%= @workout.workout_date %>" required>
            </div>
            <div class="col-md-6">
              <label for="duration_minutes" class="form-label">Duration (minutes)</label>
              <input type="number" class="form-control" id="duration_minutes" name="duration_minutes" value="<%= @workout.duration_minutes %>">
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <label for="distance_km" class="form-label">Distance (km)</label>
              <input type="number" step="0.1" class="form-control" id="distance_km" name="distance_km" value="<%= @workout.distance_km %>">
            </div>
            <div class="col-md-4">
              <label for="heart_rate_avg" class="form-label">Avg Heart Rate (bpm)</label>
              <input type="number" class="form-control" id="heart_rate_avg" name="heart_rate_avg" value="<%= @workout.heart_rate_avg %>">
            </div>
            <div class="col-md-4">
              <label for="heart_rate_max" class="form-label">Max Heart Rate (bpm)</label>
              <input type="number" class="form-control" id="heart_rate_max" name="heart_rate_max" value="<%= @workout.heart_rate_max %>">
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="calories" class="form-label">Calories Burned</label>
              <input type="number" class="form-control" id="calories" name="calories" value="<%= @workout.calories %>">
            </div>
            <div class="col-md-6">
              <label for="category_id" class="form-label">Category</label>
              <select class="form-select" id="category_id" name="category_id">
                <% Category.all.each do |category| %>
                  <option value="<%= category.id %>" <%= "selected" if @workout.category_id == category.id %>><%= category_icon(category.name) %> <%= category.name %></option>
                <% end %>
              </select>
            </div>
          </div>

          <div class="mb-4">
            <label for="notes" class="form-label">Notes</label>
            <textarea class="form-control" id="notes" name="notes" rows="3"><%= @workout.notes %></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg w-100">
            <i class="bi bi-check-lg"></i> Update Workout
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

