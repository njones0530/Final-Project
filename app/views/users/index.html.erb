<h2 class="mb-4"><i class="bi bi-people"></i> Find Friends</h2>

<!-- Search -->
<form action="<%= users_path %>" method="get" class="mb-4">
  <div class="input-group">
    <input type="text" class="form-control" name="query" placeholder="Search by username or email..." value="<%= params[:query] %>">
    <button type="submit" class="btn btn-dark">
      <i class="bi bi-search"></i> Search
    </button>
  </div>
</form>

<div class="row g-3">
  <% @users.each do |user| %>
    <div class="col-md-4">
      <div class="user-card">
        <div class="fs-1 mb-2">👤</div>
        <h5>
          <a href="<%= user_path(user) %>" class="text-decoration-none text-dark">
            <%= user.display_name %>
          </a>
        </h5>
        <p class="text-muted small mb-3">
          <%= user.total_workouts %> workouts · <%= user.total_distance.round(1) %> km
        </p>

        <% if current_user.follows?(user) %>
          <% friendship = current_user.sent_friendships.find_by(followed_id: user.id) %>
          <%= link_to friendship_path(friendship), data: { "turbo-method": :delete }, class: "btn btn-outline-secondary btn-sm" do %>
            <i class="bi bi-person-check"></i> Following
          <% end %>
        <% else %>
          <form action="<%= friendships_path %>" method="post" style="display:inline;">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <input type="hidden" name="followed_id" value="<%= user.id %>">
            <button type="submit" class="btn btn-primary btn-sm">
              <i class="bi bi-person-plus"></i> Follow
            </button>
          </form>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<% if @users.empty? %>
  <div class="text-center text-muted py-5">
    <h4>No users found</h4>
    <% if params[:query].present? %>
      <p>Try a different search term.</p>
    <% else %>
      <p>Invite your friends to join FitTrack!</p>
    <% end %>
  </div>
<% end %>

