<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h2 class="text-center mb-4">🏋️ FitTrack</h2>
        <p class="text-center text-muted mb-4">Sign in to track your workouts</p>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <% if flash[:alert] %>
            <div class="alert alert-warning"><%= flash[:alert] %></div>
          <% end %>

          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <%= f.email_field :email, class: "form-control", placeholder: "you@example.com", autofocus: true %>
          </div>

          <div class="mb-4">
            <label for="password" class="form-label">Password</label>
            <%= f.password_field :password, class: "form-control", placeholder: "Your password" %>
          </div>

          <%= f.submit "Sign In", class: "btn btn-primary btn-lg w-100" %>
        <% end %>

        <hr class="my-4">

        <p class="text-center text-muted mb-0">
          Don't have an account? <a href="<%= new_registration_path(resource_name) %>">Sign up</a>
        </p>
      </div>
    </div>
  </div>
</div>

